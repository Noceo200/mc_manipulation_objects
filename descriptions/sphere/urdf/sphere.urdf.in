<?xml version="1.0"?>
<robot name="sphere">
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
       <geometry>
        <mesh filename="@MESH_DIR@/sphere.STL"/>
      </geometry>
      <material name="sphere_material">
        <color rgba="0.85 0.85 0.20 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="@MESH_DIR@/sphere.STL"/>
      </geometry>
    </collision>
  </link>
</robot>