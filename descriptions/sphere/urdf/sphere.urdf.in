<?xml version="1.0"?>
<robot name="sphere">
  <link name="sphere_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="1.0" />
      <inertia ixx="0.00400000" ixy="0.0" ixz="0.0" iyy="0.00400000" iyz="0.0" izz="0.00400000" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
       <geometry>
        <mesh filename="@MESH_DIR@/sphere.STL"/>
      </geometry>
      <material name="sphere_material">
        <color rgba="0.85 0.85 0.20 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="@MESH_DIR@/sphere.STL"/>
      </geometry>
    </collision>
  </link>
</robot>