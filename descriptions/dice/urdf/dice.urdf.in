<?xml version="1.0"?>
<robot name="dice">
  <link name="dice_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="@MESH_DIR@/dice.STL"/>
      </geometry>
      <material name="dice_material">
        <color rgba="0.85 0.55 0.20 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="@MESH_DIR@/dice.STL"/>
      </geometry>
    </collision>
  </link>
</robot>