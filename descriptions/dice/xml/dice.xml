  <asset>
    <mesh name="body" file="dice.STL" />
  </asset>

  <worldbody>
    <body name="base_link" pos="0 0 0">
    <inertial
      pos="0 0 0"
      mass="0.086"
      diaginertia="5.73e-6 5.73e-6 5.73e-6"/>
    <joint name="root" type="free" />
    <geom
      type="mesh"
      mesh="body"
      contype="1"
      conaffinity="1"
      group="1"
      density="0"/>
    </body>
  </worldbody>
</mujoco>
