<mujoco model="dice">
  <compiler angle="radian" meshdir="../meshes"/>
  <option timestep="0.001" integrator="RK4" iterations="10" ls_iterations="10">
    <flag eulerdamp="enable"/>
  </option>
  <asset>
    <mesh name="body" file="dice.STL" />
  </asset>

  <!-- Contact stability parameters -->
  <default>
  <geom
      solref="0.02 1"
      solimp="0.9 0.95 0.001"
      friction="1.2 0.01 0.0001"/>
  </default>

  <worldbody>
    <body name="base_link" pos="0 0 0">
    <joint name="root" type="free" />
    <!-- Inertial properties computed automatically from mesh -->
    <geom
      type="mesh"
      mesh="body"
      mass="0.086"
      contype="1"
      conaffinity="1"
      group="1"
      density="0"/>
    </body>
  </worldbody>
</mujoco>
