<?xml version="1.0"?>
<robot name="wrench">
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
       <geometry>
        <mesh filename="@MESH_DIR@/wrench.STL"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
       <geometry>
        <mesh filename="@MESH_DIR@/wrench.STL"/>
      </geometry>
    </collision>
  </link>
</robot>