    <flag eulerdamp="enable"/>
  </option>
  <asset>
    <mesh name="body" file="wrench.STL"/>
  </asset>

  <worldbody>
    <body name="wrench_link" pos="0 0 0">

      <inertial
      pos="0 0 0"
      mass="0.745"
      diaginertia="0.000162 0.00237 0.00253"/>

      <joint name="root" type="free" />

        <geom
          type="mesh"
          mesh="body"
          contype="1"
          conaffinity="1"
          group="1"
          density="0"/>
    </body>
  </worldbody>
</mujoco>