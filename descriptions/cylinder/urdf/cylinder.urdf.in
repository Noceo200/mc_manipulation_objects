<?xml version="1.0"?>
<robot name="cylinder">
  <link name="cylinder_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
       <geometry>
        <mesh filename="@MESH_DIR@/cylinder.STL"/>
      </geometry>
      <material name="cylinder_material">
        <color rgba="0.20 0.55 0.90 1.0" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
       <geometry>
        <mesh filename="@MESH_DIR@/cylinder.STL"/>
      </geometry>
    </collision>
  </link>
</robot>